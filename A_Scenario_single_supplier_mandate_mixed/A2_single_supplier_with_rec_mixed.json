  "settlement_approach": {
    "type": "single_supplier_with_rec",
    "description": "Single supplier mandate WITH REC: Energy community settlement occurs after DA and ID markets but before balancing market. Internal sharing reduces supplier's external balancing needs. The KEY CHALLENGE: sharing creates imbalances as supplier uses corrected meter readings for forecasting.",
    "internal_sharing": true,
    "rec_bonuses": true,
    "balancing_responsibility": "single_supplier_balancing_group",
    "metering": {
      "load_actual": "data/load_actual.csv",
      "res_actual": "data/res_actual.csv",
      "settlement_basis": "corrected_meter_readings_after_rec_sharing"
    },
    "billing_flow": [
      "1. Single supplier purchases energy in day-ahead market based on aggregated forecasts (using corrected meter data)",
      "2. Single supplier adjusts position in intra-day market based on updated forecasts",
      "3. REC performs internal energy sharing based on actual meter readings",
      "4. Meter readings corrected: generation/load reduced proportionally based on shared energy",
      "5. Actual consumption/generation after REC settlement measured (corrected readings)",
      "6. Single supplier handles remaining imbalances in balancing market (PROBLEM: sharing creates forecasting gaps)",
      "7. Single supplier bills all customers based on corrected meter readings (residual energy only)",
      "8. Members benefit from REC internal prices and bonuses for shared energy"
    ],
    "rec_settlement_algorithm": {
      "type": "proportional_sharing",
      "steps": [
        "1. Sum total generation (Gen_total) and total load (Load_total) in REC at each timestamp",
        "2. If Gen_total == Load_total: All generation and load treated as 0 for external billing",
        "3. If Gen_total < Load_total: All generation set to 0, each load reduced proportionally by Gen_total",
        "4. If Gen_total > Load_total: All load set to 0, each generation reduced proportionally by Load_total",
        "5. Edge case: If proportional share exceeds individual meter, set to 0 and redistribute to others",
        "6. Corrected meter readings used for supplier billing"
      ]
    }
  },
